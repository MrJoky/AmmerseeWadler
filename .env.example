# Hugo / public build-time values
HUGO_BASEURL=https://your-github-user.github.io/your-repo/
RAR_RACE_START=2026-07-25T12:58:00+02:00
RAR_RACE_HOURS=24
RAR_LAP_DISTANCE_KM=19.6
RAR_RACEMAP_EVENT_ID=
RAR_RACEMAP_PROXY_URL=

# Firebase web config
# Diese Werte sind fuer Firebase Web Apps nicht geheim, gehoeren aber trotzdem nicht hartcodiert ins Repo.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Nur fuer lokale Firebase Functions Entwicklung.
# In Produktion als Firebase Secret setzen:
# firebase functions:secrets:set RACEMAP_API_TOKEN
RACEMAP_API_TOKEN=
